<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>DM Monitor -- 8BFR Owner</title>
<link rel="icon" href="assets/images/favicon.png">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{--primary:#7c3aed;--card:#0c0618;--text:#eae6ff;--dim:#a855f7;--border:rgba(124,58,237,.35);--green:#059669;--red:#dc2626;--cyan:#00d9ff;--gold:#fbbf24;--bg:#0b0014;--text-dim:rgba(234,230,255,.55);}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Work Sans',sans-serif;background:linear-gradient(var(--bg),#000);color:var(--text);min-height:100vh;padding-bottom:80px;}
.header{background:rgba(15,0,30,.95);border-bottom:2px solid var(--red);padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px);}
.header h1{font-family:'Bebas Neue',cursive;font-size:1.4rem;color:var(--red);letter-spacing:1px;}
.header-links{display:flex;align-items:center;gap:1rem;}
.header-links a{color:var(--text-dim);text-decoration:none;font-size:0.85rem;}
.stealth-badge{background:rgba(220,38,38,.15);border:1px solid rgba(220,38,38,.4);color:var(--red);padding:.25rem .6rem;border-radius:20px;font-size:.7rem;font-weight:700;letter-spacing:.5px;}
.container{max-width:900px;margin:0 auto;padding:1.5rem 1rem;}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.25rem;margin-bottom:1rem;}
.card h2{font-family:'Bebas Neue',cursive;font-size:1.2rem;color:var(--dim);margin-bottom:1rem;}
.search-row{display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap;}
.search-input{flex:1;min-width:150px;background:rgba(124,58,237,.1);border:1px solid var(--border);border-radius:8px;padding:.6rem .8rem;color:var(--text);font-size:.85rem;outline:none;}
.search-input:focus{border-color:var(--primary);box-shadow:0 0 8px rgba(124,58,237,.3);}
.btn{padding:.5rem 1rem;border-radius:8px;font-weight:600;font-size:.8rem;cursor:pointer;border:none;transition:all .2s;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{background:#6d28d9;}
.btn-sm{padding:.3rem .6rem;border-radius:6px;font-size:.72rem;font-weight:600;cursor:pointer;border:none;transition:all .2s;}
.btn-del{background:rgba(220,38,38,.15);color:var(--red);border:1px solid rgba(220,38,38,.4);}
.stats-row{display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:1rem;}
.mini-stat{background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.2);border-radius:10px;padding:.6rem .8rem;text-align:center;flex:1;min-width:80px;}
.mini-stat .num{font-family:'Bebas Neue',cursive;font-size:1.4rem;color:var(--primary);}
.mini-stat .label{font-size:.65rem;color:var(--text-dim);text-transform:uppercase;}
.convo-card{background:rgba(124,58,237,.06);border:1px solid rgba(124,58,237,.2);border-radius:10px;padding:.75rem;margin-bottom:.5rem;cursor:pointer;transition:all .2s;}
.convo-card:hover{border-color:var(--primary);background:rgba(124,58,237,.1);}
.convo-card.active{border-color:var(--primary);background:rgba(124,58,237,.12);}
.convo-header{display:flex;align-items:center;gap:.6rem;}
.convo-avatars{display:flex;}
.convo-avatars img{width:30px;height:30px;border-radius:50%;border:2px solid var(--card);object-fit:cover;}
.convo-avatars img:nth-child(2){margin-left:-10px;}
.convo-names{flex:1;min-width:0;}
.convo-names .names{font-weight:600;font-size:.82rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.convo-names .preview{font-size:.72rem;color:var(--text-dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:.1rem;}
.convo-time{font-size:.68rem;color:var(--text-dim);flex-shrink:0;}
.msg-list{display:flex;flex-direction:column;gap:.4rem;max-height:500px;overflow-y:auto;padding:.5rem;}
.msg-bubble{max-width:85%;padding:.5rem .75rem;border-radius:10px;font-size:.82rem;line-height:1.4;}
.msg-sender{background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.25);align-self:flex-start;}
.msg-receiver{background:rgba(0,217,255,.08);border:1px solid rgba(0,217,255,.2);align-self:flex-end;}
.msg-meta{font-size:.65rem;color:var(--text-dim);margin-top:.2rem;}
.msg-name{font-weight:600;font-size:.72rem;color:var(--dim);margin-bottom:.15rem;}
.empty{text-align:center;padding:2rem;color:var(--text-dim);font-size:.85rem;}
.spinner{width:24px;height:24px;border:3px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .7s linear infinite;margin:1rem auto;}
@keyframes spin{to{transform:rotate(360deg);}}
.warning-box{background:rgba(220,38,38,.08);border:1px solid rgba(220,38,38,.3);border-radius:10px;padding:.75rem;margin-bottom:1rem;font-size:.78rem;color:rgba(234,230,255,.7);}
</style>
</head>
<body>
<div class="header">
    <h1>DM Monitor</h1>
    <div class="header-links">
        <span class="stealth-badge">STEALTH MODE</span>
        <a href="owner-panel.html">&larr; Panel</a>
    </div>
</div>
<div class="container">

    <div class="warning-box">
        Owner-only. Users cannot see that you are viewing their messages. This access is for safety and moderation purposes only.
    </div>

    <!-- STATS -->
    <div class="stats-row" id="dmStats">
        <div class="mini-stat"><div class="num" id="statTotal">--</div><div class="label">Total DMs</div></div>
        <div class="mini-stat"><div class="num" id="statConvos">--</div><div class="label">Conversations</div></div>
        <div class="mini-stat"><div class="num" id="statToday">--</div><div class="label">Today</div></div>
        <div class="mini-stat"><div class="num" id="statUsers">--</div><div class="label">Active Users</div></div>
    </div>

    <!-- SEARCH -->
    <div class="search-row">
        <input type="text" class="search-input" id="searchBox" placeholder="Search by username or message content..." onkeyup="if(event.key==='Enter')searchDMs()">
        <button class="btn btn-primary" onclick="searchDMs()">Search</button>
        <button class="btn btn-primary" onclick="loadConversations()" style="background:rgba(124,58,237,.3);">All</button>
    </div>

    <!-- CONVERSATIONS -->
    <div class="card">
        <h2>Conversations</h2>
        <div id="convoList"><div class="spinner"></div></div>
    </div>

    <!-- MESSAGE VIEWER -->
    <div class="card" id="messageViewer" style="display:none;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;">
            <h2 id="viewerTitle">Messages</h2>
            <button class="btn-sm btn-del" onclick="document.getElementById('messageViewer').style.display='none'">Close</button>
        </div>
        <div class="msg-list" id="msgList"></div>
    </div>

</div>
<div style="text-align:center;padding:1rem 0;font-size:.72rem;color:rgba(168,85,247,.3);">Copyright 2025-2026 8BFR Music Network</div>
<script src="scripts.js" defer></script>
<script>
var db=supabase.createClient('https://novbuvwpjnxwwvdekjhr.supabase.co','eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5vdmJ1dndwam54d3d2ZGVramhyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjExODkxODUsImV4cCI6MjA3Njc2NTE4NX0.1UUkdGafh6ZplAX8hi7Bvj94D2gvFQZUl0an1RvcSA0');
var OWNER_ID='cb556180-f032-4b21-9470-1d786f2664ab';
var profileMap={};

async function init(){
    var s=await db.auth.getSession();
    if(!s.data.session){location.href='login.html';return;}
    if(s.data.session.user.id!==OWNER_ID){
        document.querySelector('.container').innerHTML='<div class="empty">Owner access only.</div>';
        return;
    }
    await loadProfiles();
    await loadStats();
    await loadConversations();
}

async function loadProfiles(){
    var {data}=await db.from('profiles').select('user_id,display_name,username,avatar_url');
    if(data) data.forEach(function(p){profileMap[p.user_id]=p;});
}

async function loadStats(){
    try{
        var {count:total}=await db.from('direct_messages').select('id',{count:'exact',head:true});
        document.getElementById('statTotal').textContent=total||0;

        // Unique conversation pairs
        var {data:msgs}=await db.from('direct_messages').select('sender_id,receiver_id');
        var pairs={};
        var activeUsers={};
        if(msgs) msgs.forEach(function(m){
            var key=[m.sender_id,m.receiver_id].sort().join('-');
            pairs[key]=true;
            activeUsers[m.sender_id]=true;
            activeUsers[m.receiver_id]=true;
        });
        document.getElementById('statConvos').textContent=Object.keys(pairs).length;
        document.getElementById('statUsers').textContent=Object.keys(activeUsers).length;

        // Today count
        var today=new Date();
        today.setHours(0,0,0,0);
        var {count:todayCount}=await db.from('direct_messages').select('id',{count:'exact',head:true}).gte('created_at',today.toISOString());
        document.getElementById('statToday').textContent=todayCount||0;
    }catch(e){}
}

async function loadConversations(){
    var el=document.getElementById('convoList');
    el.innerHTML='<div class="spinner"></div>';
    try{
        var {data:msgs,error}=await db.from('direct_messages').select('id,sender_id,receiver_id,message,created_at').order('created_at',{ascending:false}).limit(500);
        if(error)throw error;
        if(!msgs||!msgs.length){el.innerHTML='<div class="empty">No DMs found.</div>';return;}

        // Group by conversation pair
        var convos={};
        msgs.forEach(function(m){
            var key=[m.sender_id,m.receiver_id].sort().join('-');
            if(!convos[key]){
                convos[key]={
                    user1:m.sender_id<m.receiver_id?m.sender_id:m.receiver_id,
                    user2:m.sender_id<m.receiver_id?m.receiver_id:m.sender_id,
                    lastMsg:m.message,
                    lastTime:m.created_at,
                    count:0
                };
            }
            convos[key].count++;
        });

        var sorted=Object.keys(convos).sort(function(a,b){
            return new Date(convos[b].lastTime)-new Date(convos[a].lastTime);
        });

        el.innerHTML=sorted.map(function(key){
            var c=convos[key];
            var p1=profileMap[c.user1]||{};
            var p2=profileMap[c.user2]||{};
            var av1=p1.avatar_url||'assets/images/default-avatar.png';
            var av2=p2.avatar_url||'assets/images/default-avatar.png';
            var name1=p1.display_name||p1.username||'Unknown';
            var name2=p2.display_name||p2.username||'Unknown';
            var timeAgo=ago(c.lastTime);
            var preview=(c.lastMsg||'').substring(0,50);
            if(c.lastMsg&&c.lastMsg.length>50) preview+='...';

            return '<div class="convo-card" onclick="openConvo(\''+c.user1+'\',\''+c.user2+'\',\''+esc(name1)+' &amp; '+esc(name2)+'\')">'+
                '<div class="convo-header">'+
                '<div class="convo-avatars">'+
                '<img src="'+av1+'" onerror="this.src=\'assets/images/default-avatar.png\'">'+
                '<img src="'+av2+'" onerror="this.src=\'assets/images/default-avatar.png\'">'+
                '</div>'+
                '<div class="convo-names">'+
                '<div class="names">'+esc(name1)+' &harr; '+esc(name2)+'</div>'+
                '<div class="preview">'+esc(preview)+'</div>'+
                '</div>'+
                '<div class="convo-time">'+timeAgo+'<br>'+c.count+' msgs</div>'+
                '</div></div>';
        }).join('');
    }catch(e){el.innerHTML='<div class="empty">Error: '+e.message+'</div>';}
}

async function openConvo(uid1,uid2,title){
    var viewer=document.getElementById('messageViewer');
    var list=document.getElementById('msgList');
    document.getElementById('viewerTitle').innerHTML=title;
    viewer.style.display='block';
    list.innerHTML='<div class="spinner"></div>';
    viewer.scrollIntoView({behavior:'smooth'});

    try{
        var {data:msgs,error}=await db.from('direct_messages').select('id,sender_id,receiver_id,message,created_at')
            .or('and(sender_id.eq.'+uid1+',receiver_id.eq.'+uid2+'),and(sender_id.eq.'+uid2+',receiver_id.eq.'+uid1+')')
            .order('created_at',{ascending:true}).limit(200);
        if(error)throw error;
        if(!msgs||!msgs.length){list.innerHTML='<div class="empty">No messages in this conversation.</div>';return;}

        list.innerHTML=msgs.map(function(m){
            var sender=profileMap[m.sender_id]||{};
            var senderName=sender.display_name||sender.username||'Unknown';
            var isUser1=m.sender_id===uid1;
            var time=new Date(m.created_at).toLocaleString();
            return '<div class="msg-bubble '+(isUser1?'msg-sender':'msg-receiver')+'">'+
                '<div class="msg-name">'+esc(senderName)+'</div>'+
                esc(m.message||'')+
                '<div class="msg-meta">'+time+'</div>'+
            '</div>';
        }).join('');
        list.scrollTop=list.scrollHeight;
    }catch(e){list.innerHTML='<div class="empty">Error: '+e.message+'</div>';}
}

async function searchDMs(){
    var q=document.getElementById('searchBox').value.trim().toLowerCase();
    if(!q){loadConversations();return;}
    var el=document.getElementById('convoList');
    el.innerHTML='<div class="spinner"></div>';

    try{
        // Search by message content
        var {data:msgs}=await db.from('direct_messages').select('id,sender_id,receiver_id,message,created_at')
            .ilike('message','%'+q+'%').order('created_at',{ascending:false}).limit(100);

        // Also search by username
        var matchedUsers=Object.keys(profileMap).filter(function(uid){
            var p=profileMap[uid];
            return (p.username||'').toLowerCase().includes(q)||(p.display_name||'').toLowerCase().includes(q);
        });

        if(matchedUsers.length&&(!msgs||!msgs.length)){
            // Search messages involving matched users
            var {data:userMsgs}=await db.from('direct_messages').select('id,sender_id,receiver_id,message,created_at')
                .or(matchedUsers.map(function(u){return 'sender_id.eq.'+u+',receiver_id.eq.'+u;}).join(','))
                .order('created_at',{ascending:false}).limit(100);
            msgs=(msgs||[]).concat(userMsgs||[]);
        }

        if(!msgs||!msgs.length){el.innerHTML='<div class="empty">No messages matching "'+esc(q)+'"</div>';return;}

        // Show as flat list of matching messages
        el.innerHTML=msgs.map(function(m){
            var sender=profileMap[m.sender_id]||{};
            var receiver=profileMap[m.receiver_id]||{};
            var time=ago(m.created_at);
            return '<div class="convo-card" onclick="openConvo(\''+m.sender_id+'\',\''+m.receiver_id+'\',\''+esc(sender.display_name||'?')+' &amp; '+esc(receiver.display_name||'?')+'\')">'+
                '<div class="convo-header">'+
                '<div class="convo-names" style="flex:1;">'+
                '<div class="names">'+esc(sender.display_name||sender.username||'?')+' &rarr; '+esc(receiver.display_name||receiver.username||'?')+'</div>'+
                '<div class="preview">'+esc((m.message||'').substring(0,80))+'</div>'+
                '</div>'+
                '<div class="convo-time">'+time+'</div>'+
                '</div></div>';
        }).join('');
    }catch(e){el.innerHTML='<div class="empty">Error: '+e.message+'</div>';}
}

function ago(d){
    if(!d)return '?';
    var s=Math.floor((Date.now()-new Date(d).getTime())/1000);
    if(s<60)return s+'s ago';
    if(s<3600)return Math.floor(s/60)+'m ago';
    if(s<86400)return Math.floor(s/3600)+'h ago';
    return Math.floor(s/86400)+'d ago';
}
function esc(s){var d=document.createElement('div');d.textContent=s||'';return d.innerHTML;}

init();
</script>
</body>
</html>
