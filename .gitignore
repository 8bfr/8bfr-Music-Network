# ─────────────────────────────────────────────────────────
# 8BFR Music Network — .gitignore
# Protects against accidentally committing secrets or junk
# ─────────────────────────────────────────────────────────

# ── Secret / env files (NEVER commit these) ──
.env
.env.*
*.env
.env.local
.env.production
.env.development
secrets.json
credentials.json
service-account*.json

# ── Local helper + backup files ──
8bfr_quick_commands.txt
autobackup.sh.bak
site_backups/
termux_commands_8bfr_full.txt
*.bak
*.backup
*.old
*~
*.swp
*.swo

# ── OS junk ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE files ──
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.cursor/

# ── Node / package manager output (if you ever add npm) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# ── Logs & debug output ──
*.log
logs/
debug.log
error.log

# ── Local database dumps / exports ──
*.sql.bak
*.dump
db-export-*.json
user-export-*.csv

# ── Build artifacts (if you add a build step later) ──
dist/
build/
out/
.cache/

# ── Termux temp files ──
.termux-tmp/
*.tmp

# ── Personal notes that shouldn't be public ──
notes.md
TODO-private.md
ideas-private.md
